rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // User Profile Rules
    // users collection docs are keyed by their auth uid
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Job Application Rules
    match /job_applications/{applicationId} {
      // Create: user must be authenticated, and must set userId to their own UID
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Read, Update, Delete: existing document must belong to the user
      allow read, update, delete: if isOwner(resource.data.userId);
    }
  }
}
